# ============================================================
# LLM 聊天配置
# ============================================================
# API 密钥（必填）。支持 OpenAI / DeepSeek / SiliconFlow 等。
LLM_API_KEY=sk-your-api-key-here

# API 端点地址（按服务商修改）
# OpenAI:   https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Ollama:   http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# 聊天模型名称
# OpenAI:   gpt-4o-mini / gpt-4o
# DeepSeek: deepseek-chat / deepseek-v3 / deepseek-v4-flash
# Ollama:   llama3 / qwen2.5
LLM_MODEL=gpt-4o-mini

# ============================================================
# Embedding / 向量化配置（可独立于聊天 API）
# ============================================================
# 留空则复用 LLM_BASE_URL 和默认模型 text-embedding-ada-002
# 如果你的聊天 API 不支持 Embedding（如 DeepSeek），需单独配置：
#
# SiliconFlow（免费赠金，无需绑卡）:
#   EMBEDDING_BASE_URL=https://api.siliconflow.com/v1
#   EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
#
# Ollama 本地（完全免费）:
#   EMBEDDING_BASE_URL=http://localhost:11434/v1
#   EMBEDDING_MODEL=nomic-embed-text
#
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-ada-002
# EMBEDDING_API_KEY=    # 与 LLM_API_KEY 不同时取消注释

# ============================================================
# 网页搜索（可选）
# ============================================================
SERP_API_KEY=

# ============================================================
# Rerank 重排配置（可选，大幅提升排序质量）
# ============================================================
# 重排器在向量检索后对结果进行二次精排。
# 使用交叉编码器（cross-encoder），精度高于单纯双编码器（bi-encoder）的余弦相似度。
#
# SiliconFlow（推荐）:
#   RERANK_BASE_URL=https://api.siliconflow.com/v1
#   RERANK_MODEL=BAAI/bge-reranker-v2-m3
#
# 留空则不启用重排，检索结果仅按向量相似度排序。
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
